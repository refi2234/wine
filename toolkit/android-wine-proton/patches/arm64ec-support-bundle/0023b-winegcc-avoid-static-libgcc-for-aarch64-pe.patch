From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: OpenAI Codex <codex@openai.com>
Date: Wed, 22 Apr 2026 11:20:00 +0300
Subject: [PATCH] winegcc: avoid -static-libgcc for aarch64 PE builds under LLVM

---
 tools/winegcc/winegcc.c | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/tools/winegcc/winegcc.c b/tools/winegcc/winegcc.c
index a6b91a4..9c23919 100644
--- a/tools/winegcc/winegcc.c
+++ b/tools/winegcc/winegcc.c
@@ -420,8 +420,10 @@ static struct strarray get_link_args( struct options *opts, const char *output_n
         if (opts->large_address_aware && opts->target.cpu == CPU_i386)
             strarray_add( &flags, "-Wl,--large-address-aware" );
 
-        /* make sure we don't need a libgcc_s dll on Windows */
-        if (!opts->nodefaultlibs && !opts->use_msvcrt)
+        /* LLVM aarch64 PE builds may not provide a MinGW libgcc archive. */
+        if (!opts->nodefaultlibs && !opts->use_msvcrt &&
+            !(opts->target.cpu == CPU_ARM64 &&
+              strarray_exists( link_args, "-fuse-ld=lld" )))
             strarray_add( &flags, "-static-libgcc" );
 
         if (opts->debug_file && strendswith(opts->debug_file, ".pdb"))
