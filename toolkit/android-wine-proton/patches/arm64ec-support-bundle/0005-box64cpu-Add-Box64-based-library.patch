+#define INTR_RAISE_DIV0(emu) {emu->error |= ERR_DIVBY0;} // should rise a SIGFPE and not quit
+
+void applyFlushTo0(x64emu_t* emu);
+
+#endif //__X86EMU_PRIVATE_H_
