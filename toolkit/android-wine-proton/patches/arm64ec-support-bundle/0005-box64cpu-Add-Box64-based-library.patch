+int getMmapped(uintptr_t addr)
+{
+    mapmem_t* m = mmapmem;
+    if(addr<box64_pagesize) return 0;
+    while(m) {
+        uintptr_t begin = m->begin;
+        uintptr_t end = m->end;
+        if(addr>=begin && addr<=end)
+            return 1;
+        if(addr<begin)
