+uint32_t getProtection(uintptr_t addr)
+{
+    if(addr>=(1LL<<48))
+        return 0;
+    LOCK_NODYNAREC();
+    const uintptr_t idx = (addr>>MEMPROT_SHIFT);
+    uint8_t *block = getProtBlock(idx>>16, 0);
