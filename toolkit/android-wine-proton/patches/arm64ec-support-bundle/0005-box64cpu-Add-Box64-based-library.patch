+/****************************************************************************
+REMARKS:
+Implements the SHLD instruction and side effects.
+****************************************************************************/
+uint16_t shld16 (x64emu_t *emu, uint16_t d, uint16_t fill, uint8_t s)
+{
+	unsigned int cnt, res, cf;
+	RESET_FLAGS(emu);
+
+	s = s&0x1f;
+	cnt = s % 16;
+	if (s < 16) {
+		if (cnt > 0) {
+			res = (d << cnt) | (fill >> (16-cnt));
+			cf = d & (1 << (16 - cnt));
+			CONDITIONAL_SET_FLAG(cf, F_CF);
+			CONDITIONAL_SET_FLAG((res & 0xffff) == 0, F_ZF);
+			CONDITIONAL_SET_FLAG(res & 0x8000, F_SF);
+			CONDITIONAL_SET_FLAG(PARITY(res & 0xff), F_PF);
+		} else {
+			res = d;
+		}
+		if (cnt == 1) {
+			CONDITIONAL_SET_FLAG(((res ^ d) >> 15)&1, F_OF);
+		} else {
+			CLEAR_FLAG(F_OF);
+		}
+	} else {
+		res = (fill << (cnt)) | (d >> (16 - cnt));
+		if(s==16)
+			cf = d & 1;
+		else
+			cf = fill & (1 << (16 - cnt));
+		CONDITIONAL_SET_FLAG(cf, F_CF);
+		CONDITIONAL_SET_FLAG((res & 0xffff) == 0, F_ZF);
+		CONDITIONAL_SET_FLAG(res & 0x8000, F_SF);
+		CONDITIONAL_SET_FLAG(PARITY(res & 0xff), F_PF);
+		CLEAR_FLAG(F_OF);
+	}
+	return (uint16_t)res;
+}
+
+uint32_t shld32 (x64emu_t *emu, uint32_t d, uint32_t fill, uint8_t s)
+{
+	unsigned int cnt, res, cf;
+	RESET_FLAGS(emu);
+
+	s = s&0x1f;
+	cnt = s % 32;
+	if (cnt > 0) {
+		res = (d << cnt) | (fill >> (32-cnt));
+		cf = d & (1 << (32 - cnt));
+		CONDITIONAL_SET_FLAG(cf, F_CF);
+		CONDITIONAL_SET_FLAG(!res, F_ZF);
+		CONDITIONAL_SET_FLAG(res & 0x80000000, F_SF);
+		CONDITIONAL_SET_FLAG(PARITY(res & 0xff), F_PF);
+	} else {
+		res = d;
+	}
+	if (cnt == 1) {
+		CONDITIONAL_SET_FLAG(((res ^ d) >> 31)&1, F_OF);
+	} else {
+		CLEAR_FLAG(F_OF);
+	}
+	return res;
+}
+
+uint64_t shld64 (x64emu_t *emu, uint64_t d, uint64_t fill, uint8_t s)
+{
+	uint64_t cnt, res, cf;
+	RESET_FLAGS(emu);
+
+	s = s&0x3f;
+	cnt = s % 64;
+	if (cnt > 0) {
+		res = (d << cnt) | (fill >> (64-cnt));
+		cf = d & (1LL << (64 - cnt));
+		CONDITIONAL_SET_FLAG(cf, F_CF);
+		CONDITIONAL_SET_FLAG(!res, F_ZF);
+		CONDITIONAL_SET_FLAG(res & 0x8000000000000000LL, F_SF);
+		CONDITIONAL_SET_FLAG(PARITY(res & 0xff), F_PF);
+	} else {
+		res = d;
+	}
+	if (cnt == 1) {
+		CONDITIONAL_SET_FLAG(((res ^ d) >> 63)&1, F_OF);
+	} else {
+		CLEAR_FLAG(F_OF);
+	}
+	return res;
+}
