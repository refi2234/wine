+        ANDw_mask(s4, s1, 0, 0);        // s4 = op1 & op2
+    }
+    ADDw_U12(s1, s1, 1);
+    IFX(X_PEND) {
+        STRB_U12(s1, xEmu, offsetof(x64emu_t, res));
+    }
+    IFX(X_AF|X_OF) {
