+                                GD->q[0] = imul32(emu, GD->dword[0], ED->dword[0]);
+                            break;
+                        default:
+                            return 0;
+                    }
+                    break;
+
+                case 0xB6:
+                    switch(rep) {
+                        case 0: /* MOVZX Gd, FS:Eb */
+                            nextop = F8;
+                            GETEB_OFFS(0, tlsdata);
+                            GETGD;
+                            GD->q[0] = EB->byte[0];
+                            break;
+                        default:
+                            return 0;
+                    }
+                    break;
+                case 0xB7:
+                    switch(rep) {
+                        case 0: /* MOVZX Gd, FS:Ew */
