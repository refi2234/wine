+    #endif
+    // create and add new block
+    if (box64_dynarec_log) dynarec_log(LOG_VERBOSE, "Ask for DynaRec Block creation @%p\n", (void*)addr);
+    block = (dynablock_t*)customCalloc(1, sizeof(dynablock_t));
+    return block;
+}
