+                            memcpy(GX, EX, 16);    // unaligned...
+                            break;
+                            
+                        default:
+                            return 0;
+                    }
+                    break;
+
+                case 0xAF:
+                    switch(rep) {
+                        case 0: /* IMUL Gd, FS:Ed */
+                            nextop = F8;
+                            GETED_OFFS(0, tlsdata);
+                            GETGD;
+                            if(rex.w)
+                                GD->q[0] = imul64(emu, GD->q[0], ED->q[0]);
