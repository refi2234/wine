+	d_adc16,
+	d_adc32,
+	d_adc32b,
+	d_adc64,
+	d_sbb8,
+	d_sbb16, 
+	d_sbb32,
+	d_sbb64,
+	d_rol8,
+	d_rol16,
+	d_rol32,
+	d_rol64,
+	d_ror8,
