+                            }
+                            break;
+                        default:
+                            return 0;
+                    }
+                    break;
+                case 0x11:
+                    switch(rep) {
+                        case 0: /* MOVUPS FS:Ex, Gx */
+                            nextop = F8;
+                            GETEX_OFFS(0, tlsdata);
+                            GETGX;
+                            EX->u128 = GX->u128;
+                            break;
+                        case 1: /* MOVSD Ex, Gx */
+                            nextop = F8;
+                            GETEX_OFFS(0, tlsdata);
+                            GETGX;
+                            EX->q[0] = GX->q[0];
+                            break;
+                        case 2: /* MOVSS FS:Ex, Gx */
+                            nextop = F8;
+                            GETEX_OFFS(0, tlsdata);
