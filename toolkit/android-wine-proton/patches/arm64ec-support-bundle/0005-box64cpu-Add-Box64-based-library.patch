index 00000000000..0e1d71c36a7
--- /dev/null
+++ b/libs/box64/src/dynarec/arm64/dynarec_arm64_6764_32.c
@@ -0,0 +1,105 @@
+#include <stdio.h>
+#include <stdlib.h>
+#include <stddef.h>
+#include <errno.h>
+
+#include "debug.h"
+#include "box64context.h"
