+int IsInHotPage(uintptr_t addr) {
+    if(addr>=(1LL<<48))
+        return 0;
+    int idx = (addr>>MEMPROT_SHIFT)>>16;
+    uint8_t *hot = (uint8_t*)native_lock_get_dd(&memprot[idx].hot);
+    if(!hot)
+        return 0;
+    int base = (addr>>MEMPROT_SHIFT)&0xffff;
+    if(!hot[base])
