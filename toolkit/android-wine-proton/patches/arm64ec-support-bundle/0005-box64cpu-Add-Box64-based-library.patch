index 00000000000..3903eb6816b
--- /dev/null
+++ b/libs/box64/src/dynarec/dynarec.c
@@ -0,0 +1,245 @@
+#include <stdio.h>
+#include <stdlib.h>
+#include <errno.h>
+#include <setjmp.h>
+
+#include "debug.h"
+#include "box64context.h"
