+// Branch to next instruction if reg is 0 (use j64)
+#define CBZw_NEXT(reg)    \
+    j64 =  (dyn->insts)?(dyn->insts[ninst].epilog-(dyn->native_size)):0; \
+    CBZw(reg, j64)
+// Branch to next instruction if reg is 0 (use j64)
