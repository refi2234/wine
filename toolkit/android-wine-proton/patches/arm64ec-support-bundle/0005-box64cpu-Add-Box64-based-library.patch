+// emit NEG8 instruction, from s1, store result in s1 using s3 and s4 as scratch
+void emit_neg8(dynarec_arm_t* dyn, int ninst, int s1, int s3, int s4)
+{
+    IFX(X_PEND) {
+        STRB_U12(s1, xEmu, offsetof(x64emu_t, op1));
