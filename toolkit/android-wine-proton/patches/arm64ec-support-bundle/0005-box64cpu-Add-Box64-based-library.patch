+EXPORTDYN
+void FreeX64Emu(x64emu_t **emu)
+{
+    if(!emu)
+        return;
+    printf_log(LOG_DEBUG, "%04d|Free a X86_64 Emu (%p)\n", GetTID(), *emu);
+
+    if((*emu)->test.emu) {
+        internalFreeX64((*emu)->test.emu);
+        box_free((*emu)->test.emu);
+        (*emu)->test.emu = NULL;
+    }
+    internalFreeX64(*emu);
+
+    box_free(*emu);
+    *emu = NULL;
