+
+#ifdef TEST_INTERPRETER
+uintptr_t Test67_32(x64test_t *test, rex_t rex, int rep, uintptr_t addr)
+#else
+uintptr_t Run67_32(x64emu_t *emu, rex_t rex, int rep, uintptr_t addr)
