+// Insert low 16bits in rs to low 16bits of rd
+#define INSH(rd, rs, s1, s2, init_s1, zexth_rs) \
+    if (init_s1) LUI(s1, 0xffff0);              \
+    AND(rd, rd, s1);                            \
+    if (zexth_rs) {                             \
+        ZEXTH(s2, rs);                          \
