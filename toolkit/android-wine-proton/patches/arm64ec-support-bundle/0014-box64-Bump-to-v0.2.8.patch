+// Single-bit Extract (Immediate)
+#define BEXTI(rd, rs1, imm)   \
+    if (rv64_zbs)             \
+        BEXTI_(rd, rs1, imm); \
+    else if (rv64_xtheadbs)   \
+        TH_TST(rd, rs1, imm); \
+    else {                    \
+        SRLIxw(rd, rs1, imm); \
+        ANDI(rd, rd, 1);      \
+    }
