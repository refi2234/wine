+// GETEB32 will use i for ed, and can use r3 for wback.
+#define GETEB32(i, D)                                                                             \
+    if (MODREG) {                                                                                 \
+        if (rex.rex) {                                                                            \
+            wback = xRAX + (nextop & 7) + (rex.b << 3);                                           \
+            wb2 = 0;                                                                              \
+        } else {                                                                                  \
+            wback = (nextop & 7);                                                                 \
+            wb2 = (wback >> 2) * 8;                                                               \
+            wback = xRAX + (wback & 3);                                                           \
+        }                                                                                         \
+        if (wb2) {                                                                                \
+            if (rv64_xtheadbb) {                                                                  \
+                TH_EXTU(i, wback, 15, 8);                                                         \
+            } else {                                                                              \
