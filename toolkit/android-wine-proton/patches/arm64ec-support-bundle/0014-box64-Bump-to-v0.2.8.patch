+        // OF flag is set to the most-significant bit of the original operand
+        ADDI(s3, xZR, 1);
+        BNE(s2, s3, 4 + 3 * 4);
+        SRLI(s3, s1, 7);
+        SLLI(s3, s3, F_OF2);
+        OR(xFlags, xFlags, s3);
+    }
+
+    SRL(s1, s1, s2);
+    ANDI(s1, s1, 0xff);
+
+    // SF should be unset
+    IFX(X_PEND) {
+        SB(s1, xEmu, offsetof(x64emu_t, res));
+    }
+    IFX(X_ZF) {
+        BNEZ(s1, 8);
+        ORI(xFlags, xFlags, 1 << F_ZF);
