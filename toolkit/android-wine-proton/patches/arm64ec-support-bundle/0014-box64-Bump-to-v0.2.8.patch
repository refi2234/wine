+            SCVTFDD(SCRATCH, reg);
+            VSTR64_REG_LSL3(SCRATCH, s1, s2);
+        } else {
+            VSTR64_REG_LSL3(reg, s1, s2);
+        }
+        // and forget that cache
+        fpu_free_reg(dyn, reg);
+        dyn->n.neoncache[reg].v = 0;
+        dyn->n.x87cache[ret] = -1;
+        dyn->n.x87reg[ret] = -1;
+    } else {
+        // Get top
+        LDRw_U12(s2, xEmu, offsetof(x64emu_t, top));
