+        // Get top
+        LDRw_U12(s2, xEmu, offsetof(x64emu_t, top));
+        // Update
+        int ast = st - dyn->n.x87stack;
+        if(ast) {
+            if(ast>0) {
+                ADDw_U12(s2, s2, ast);
+            } else {
+                SUBw_U12(s2, s2, -ast);
+            }
+            ANDw_mask(s2, s2, 0, 2); //mask=7    // (emu->top + i)&7
+        }
+        if(dyn->n.neoncache[reg].t==NEON_CACHE_ST_F) {
