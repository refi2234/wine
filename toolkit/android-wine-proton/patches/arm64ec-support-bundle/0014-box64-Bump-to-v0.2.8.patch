+    // c != 0
+    CLEAR_FLAGS();
+    IFX(X_PEND) {
+        MOV64x(s3, c);
+        SB(s3, xEmu, offsetof(x64emu_t, op2));
+        SB(s1, xEmu, offsetof(x64emu_t, op1));
+        SET_DF(s4, d_sar8);
+    } else IFX(X_ALL) {
