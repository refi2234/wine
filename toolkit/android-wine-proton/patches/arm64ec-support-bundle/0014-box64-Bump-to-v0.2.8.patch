+    if (!(c%9)) return;
+
+    SET_DFNONE(s4);
+
+    c%=9;
+    IFX(X_OF) {
+        MOVw_REG(s3, wFlags);
+    }
+    BFIw(s1, xFlags, 8, 1); // insert cf
