+	dynarec_rv64_66f30f
+	dynarec_rv64_67
+	dynarec_rv64_67_32
+	dynarec_rv64_d8
+	dynarec_rv64_d9
+	dynarec_rv64_da
+	dynarec_rv64_db
+	dynarec_rv64_dc
+	dynarec_rv64_dd
+	dynarec_rv64_de
