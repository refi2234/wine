+                SB(x3, gback, gdoffset + i);
+            }
+            break;
+        case 0xDD:
+            INST_NAME("PADDUSW Gx,Ex");
+            nextop = F8;
+            GETGX();
+            GETEX(x2, 0);
+            for (int i = 0; i < 8; ++i) {
+                // tmp32s = (int32_t)GX->uw[i] + EX->uw[i];
+                // GX->uw[i] = (tmp32s>65535)?65535:tmp32s;
+                LHU(x3, gback, gdoffset + i * 2);
