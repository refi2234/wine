+            SRLI(s3, rs, 56);          \
+            SRLI(s4, rs, 40);          \
+            SLLI(s2, s2, 8);           \
+            AND(s4, s4, s2);           \
+            OR(s1, s1, s3);            \
+            OR(s1, s1, s4);            \
+            SLLI(s3, rs, 40);          \
+            SLLI(s4, s2, 40);          \
+            AND(s3, s3, s4);           \
+            OR(s1, s1, s3);            \
+            SRLI(s3, rs, 24);          \
+            SLLI(s4, s2, 8);           \
+            AND(s3, s3, s4);           \
+            OR(s1, s1, s3);            \
+            SLLI(s3, rs, 24);          \
+            SLLI(s4, s2, 32);          \
+            AND(s3, s3, s4);           \
+            OR(s1, s1, s3);            \
+            SRLI(s3, rs, 8);           \
+            SLLI(s4, s2, 16);          \
+            AND(s3, s3, s4);           \
+            OR(s1, s1, s3);            \
+            SLLI(s3, rs, 8);           \
+            SLLI(s4, s2, 24);          \
+            AND(s3, s3, s4);           \
+            OR(rd, s1, s3);            \
+        } else {                       \
