+// Byte-reverse register, rd can be the same as rs or s1, but rs cannot be the same as s1.
+#define REV8xw(rd, rs, s1, s2, s3, s4) \
+    if (rv64_zbb) {                    \
+        REV8(rd, rs);                  \
+        if (!rex.w) {                  \
+            SRLI(rd, rd, 32);          \
+        }                              \
+    } else if (rv64_xtheadbb) {        \
+        if (rex.w) {                   \
+            TH_REV(rd, rs);            \
+        } else {                       \
+            TH_REVW(rd, rs);           \
