+#define EWBACK EWBACKW(ed)
+// Write w back to original register / memory (w needs to be 16bits only!)
+#define EWBACKW(w)                  \
+    if (wb1) {                      \
+        SH(w, wback, fixedaddress); \
+        SMWRITE();                  \
+    } else {                        \
+        SRLI(wback, wback, 16);     \
+        SLLI(wback, wback, 16);     \
+        OR(wback, wback, w);        \
