+//         and clear the high 32bit when x is 1.
+#define CTZxw(rd, rs, x, s1, s2)                \
+    if (rv64_zbb) {                             \
+        if (x)                                  \
+            CTZ(rd, rs);                        \
+        else                                    \
+            CTZW(rd, rs);                       \
