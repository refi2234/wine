+// Single-bit Extract (Register), s0 can be the same as rs2
+#define BEXT(rd, rs1, rs2, s0)              \
+    if (rv64_zbs)                           \
+        BEXT_(rd, rs1, rs2);                \
+    else {                                  \
+        ANDI(s0, rs2, rex.w ? 0x3f : 0x1f); \
+        SRL(rd, rs1, s0);                   \
+        ANDI(rd, rd, 1);                    \
+    }
