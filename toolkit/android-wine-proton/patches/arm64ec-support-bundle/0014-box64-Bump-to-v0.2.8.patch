+        TH_LDD(xRSI, xRDI, s0, 1);                      \
+        TH_LDD(xR8, xR9, s0, 2);                        \
+        TH_LDD(xR10, xR11, s0, 3);                      \
+    } else {                                            \
+        LOAD_REG(RBX);                                  \
+        LOAD_REG(RDX);                                  \
+        LOAD_REG(RSP);                                  \
+        LOAD_REG(RBP);                                  \
+        LOAD_REG(RDI);                                  \
+        LOAD_REG(RSI);                                  \
+        LOAD_REG(R8);                                   \
+        LOAD_REG(R9);                                   \
+        LOAD_REG(R10);                                  \
+        LOAD_REG(R11);                                  \
+    }
