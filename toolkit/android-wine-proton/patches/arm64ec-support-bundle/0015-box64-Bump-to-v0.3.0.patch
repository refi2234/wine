+        for(int i=0; i<(is32bits?8:16); ++i)
+            memcpy(&p->XmmRegisters[i], &emu->xmm[i], 16);
+    }
+    if(h->xstate_bv&0b100) {
+        sse_regs_t* avx = (sse_regs_t*)(h+1);
+        for(int i=0; i<(is32bits?8:16); ++i)
