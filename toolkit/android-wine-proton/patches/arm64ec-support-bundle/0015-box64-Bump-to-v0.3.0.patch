index 00000000000..05f548372ab
--- /dev/null
+++ b/libs/box64/src/dynarec/arm64/dynarec_arm64_67_avx.c
@@ -0,0 +1,114 @@
+#include <stdio.h>
+#include <stdlib.h>
+#include <stddef.h>
+#include <errno.h>
+
+#include "debug.h"
+#include "box64context.h"
