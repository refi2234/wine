diff --git a/dlls/box64cpu/crt.c b/dlls/box64cpu/crt.c
--- a/dlls/box64cpu/crt.c
+++ b/dlls/box64cpu/crt.c
@@ -239,3 +239,67 @@ int CDECL fesetround(int round_mode)
     _controlfp(round_mode, _MCW_RC);
     return 0;
 }
+static unsigned __int128 udivmodti4( unsigned __int128 num, unsigned __int128 den,
+                                     unsigned __int128 *rem )
+{
+    unsigned __int128 bit = 1, quot = 0;
+
+    if (!den)
+    {
+        if (rem) *rem = 0;
+        return 0;
+    }
+
+    while ((den < num) && !(den & (((unsigned __int128)1) << 127)))
+    {
+        den <<= 1;
+        bit <<= 1;
+    }
+
+    while (bit)
+    {
+        if (num >= den)
+        {
+            num -= den;
+            quot |= bit;
+        }
+        den >>= 1;
+        bit >>= 1;
+    }
+
+    if (rem) *rem = num;
+    return quot;
+}
+
+unsigned __int128 __udivti3( unsigned __int128 num, unsigned __int128 den )
+{
+    return udivmodti4( num, den, NULL );
+}
+
+__int128 __divti3( __int128 num, __int128 den )
+{
+    int neg = 0;
+    unsigned __int128 unum, uden, quot;
+
+    if (num < 0)
+    {
+        neg ^= 1;
+        unum = -(unsigned __int128)num;
+    }
+    else unum = num;
+
+    if (den < 0)
+    {
+        neg ^= 1;
+        uden = -(unsigned __int128)den;
+    }
+    else uden = den;
+
+    quot = udivmodti4( unum, uden, NULL );
+    return neg ? -(__int128)quot : (__int128)quot;
+}
+
+void __clear_cache( void *begin, void *end )
+{
+    __builtin___clear_cache( begin, end );
+}
