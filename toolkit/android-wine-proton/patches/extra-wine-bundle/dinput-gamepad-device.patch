+    }
 
     if (FAILED(hr)) return hr;
 
@@ -372,12 +376,30 @@ static HRESULT WINAPI dinput8_EnumDevices( IDirectInput8W *iface, DWORD type, LP
 
     if (device_class == DI8DEVCLASS_ALL || device_class == DI8DEVCLASS_GAMECTRL)
     {
+        BOOL skip_hid_joystick = FALSE;
+
         do
         {
-            hr = hid_joystick_enum_device( type, flags, &instance, impl->dwVersion, i++ );
-            if (hr == DI_OK && try_enum_device( device_type, callback, &instance, context, flags ) == DIENUM_STOP)
-                return DI_OK;
+            hr = gamepad_enum_device( type, flags, &instance, impl->dwVersion, i++ );
+            if (hr == DI_OK)
+            {
+                skip_hid_joystick = TRUE;
+                if (try_enum_device( device_type, callback, &instance, context, flags ) == DIENUM_STOP)
+                    return DI_OK;
+            }
         } while (SUCCEEDED(hr));
+
+        if (!skip_hid_joystick)
+        {
+            i = 0;
+
+            do
+            {
+                hr = hid_joystick_enum_device( type, flags, &instance, impl->dwVersion, i++ );
+                if (hr == DI_OK && try_enum_device( device_type, callback, &instance, context, flags ) == DIENUM_STOP)
+                    return DI_OK;
+            } while (SUCCEEDED(hr));
+        }
     }
 
     return DI_OK;
